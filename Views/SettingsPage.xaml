<Page x:Class="DSAapp.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="using:DSAapp.Helpers"
      xmlns:xaml="using:Microsoft.UI.Xaml"
      Background="Transparent">

    <Page.Resources>
        <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" Spacing="8" Padding="0,4,0,48">

            <!-- ════════════════════════════════════════
                 SECCIÓN: APARIENCIA
                 ════════════════════════════════════════ -->
            <TextBlock Text="Personalización"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>

            <!-- Item: Tema — usa el patrón de fila de Settings de Windows 11 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8,8,0,0"
                    Padding="16,0">
                <Grid MinHeight="64">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icono -->
                    <Border Grid.Column="0"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            Margin="0,0,16,0">
                        <FontIcon Glyph="&#xE771;"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="16"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <!-- Texto -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Tema de la aplicación"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Cambia entre modo claro, oscuro o el del sistema"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Control: ComboBox de tema (patrón Windows 11) -->
                    <ComboBox Grid.Column="2"
                              MinWidth="160"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="Seleccionar tema">
                        <ComboBoxItem Content="Claro"
                                      IsSelected="{x:Bind ViewModel.ElementTheme,
                                                   Converter={StaticResource EnumToBooleanConverter},
                                                   ConverterParameter=Light, Mode=OneWay}"/>
                        <ComboBoxItem Content="Oscuro"
                                      IsSelected="{x:Bind ViewModel.ElementTheme,
                                                   Converter={StaticResource EnumToBooleanConverter},
                                                   ConverterParameter=Dark, Mode=OneWay}"/>
                        <ComboBoxItem Content="Predeterminado del sistema"
                                      IsSelected="{x:Bind ViewModel.ElementTheme,
                                                   Converter={StaticResource EnumToBooleanConverter},
                                                   ConverterParameter=Default, Mode=OneWay}"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Item: Backdrop (solo visual — muestra la configuración actual) -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,8,8"
                    Padding="16,0">
                <Grid MinHeight="64">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            Margin="0,0,16,0">
                        <FontIcon Glyph="&#xE81E;"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  FontSize="16"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="Material de fondo"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Mica — usa el color de fondo de Windows"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="2"
                               Text="Activo"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════
                 SECCIÓN: ACERCA DE
                 ════════════════════════════════════════ -->
            <TextBlock Text="Acerca de"
                       Style="{ThemeResource SubtitleTextBlockStyle}"
                       FontWeight="SemiBold"
                       Margin="0,20,0,4"/>

            <!-- Card: Información de la app -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24,20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icono de la app -->
                    <Border Grid.Column="0"
                            Width="72" Height="72"
                            CornerRadius="16"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            VerticalAlignment="Top">
                        <Image Source="/Assets/WindowIcon.ico"
                               Width="44" Height="44"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <!-- Detalles -->
                    <StackPanel Grid.Column="1" Spacing="6">

                        <TextBlock Text="DSAapp"
                                   Style="{ThemeResource SubtitleTextBlockStyle}"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Gestión Institucional de Proyectos"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                        <TextBlock Text="{x:Bind ViewModel.VersionDescription, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   IsTextSelectionEnabled="True"/>

                        <Rectangle Height="1"
                                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                                   Margin="0,4"/>

                        <TextBlock Text="Sistema de administración y trazabilidad de oficios, tareas y proyectos para la Dirección de Servicios Administrativos."
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>

                        <HyperlinkButton x:Uid="SettingsPage_PrivacyTermsLink"
                                         Margin="-12,0,0,0"
                                         AutomationProperties.Name="Aviso de privacidad"/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>