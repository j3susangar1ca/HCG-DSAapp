<Page x:Class="DSAapp.Views.EscanerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:DSAapp.ViewModels"
      Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── CommandBar ── -->
        <CommandBar Grid.Row="0"
                    DefaultLabelPosition="Right"
                    Background="Transparent"
                    OverflowButtonVisibility="Collapsed">

            <!-- ★ FontIcon en lugar de Icon="Scanner" (Symbol inválido) -->
            <AppBarButton Label="Escanear"
                          Command="{x:Bind ViewModel.ScanCommand}"
                          AutomationProperties.Name="Iniciar escaneo">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE8D7;"
                              FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                </AppBarButton.Icon>
            </AppBarButton>

            <AppBarSeparator/>

            <AppBarButton Icon="Delete"
                          Label="Eliminar página"
                          Command="{x:Bind ViewModel.DeletePageCommand}"
                          CommandParameter="{x:Bind ViewModel.SelectedPage, Mode=OneWay}"
                          AutomationProperties.Name="Eliminar página seleccionada"/>

            <CommandBar.Content>
                <StackPanel Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="12,0">
                    <FontIcon Glyph="&#xE8A9;"
                              FontSize="14"
                              FontFamily="{StaticResource SymbolThemeFontFamily}"
                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalPagesScanned, Mode=OneWay}"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="páginas"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </CommandBar.Content>
        </CommandBar>

        <!-- ── Layout principal de tres columnas ── -->
        <Grid Grid.Row="1" ColumnSpacing="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- COL 0: Lista de miniaturas -->
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <ListView ItemsSource="{x:Bind ViewModel.Pages}"
                          SelectedItem="{x:Bind ViewModel.SelectedPage, Mode=TwoWay}"
                          Padding="8">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ScannedPageViewModel">
                            <Border CornerRadius="6"
                                    Padding="8"
                                    Margin="0,4">
                                <StackPanel Spacing="6">
                                    <Border CornerRadius="4"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Image Source="{x:Bind ImageSource, Mode=OneWay}"
                                               Height="160"
                                               Stretch="Uniform"/>
                                    </Border>
                                    <TextBlock Text="{x:Bind PageLabel}"
                                               HorizontalAlignment="Center"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- COL 1: Vista previa de la página seleccionada -->
            <!-- ★ Sin Translation/Vector3 — simplemente ScrollViewer con ZoomMode -->
            <ScrollViewer Grid.Column="1"
                          ZoomMode="Enabled"
                          MinZoomFactor="0.25"
                          MaxZoomFactor="4.0"
                          Background="{ThemeResource LayerFillColorDefaultBrush}"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Image Source="{x:Bind ViewModel.SelectedPage.ImageSource, Mode=OneWay}"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="24"/>
            </ScrollViewer>

            <!-- COL 2: Panel OCR -->
            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid Padding="16" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Encabezado OCR -->
                    <StackPanel Grid.Row="0" Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8D2;"
                                      FontSize="16"
                                      FontFamily="{StaticResource SymbolThemeFontFamily}"
                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                      VerticalAlignment="Center"/>
                            <TextBlock Text="Texto reconocido (OCR)"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Height="1"
                                   Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                    </StackPanel>

                    <!-- Área de texto OCR -->
                    <TextBox Grid.Row="1"
                             Text="{x:Bind ViewModel.SelectedPage.ExtractedText, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             FontSize="12"
                             PlaceholderText="El texto reconocido aparecerá aquí..."
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             AutomationProperties.Name="Texto OCR extraído"/>

                    <!-- Botón copiar -->
                    <Button Grid.Row="2"
                            Content="Copiar texto al portapapeles"
                            Click="CopyText_Click"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.Name="Copiar texto OCR"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
