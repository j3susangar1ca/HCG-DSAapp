<Page x:Class="DSAapp.Views.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="using:DSAapp.Helpers"
      xmlns:behaviors="using:DSAapp.Behaviors"
      xmlns:i="using:Microsoft.Xaml.Interactivity"
      Loaded="OnLoaded">

    <Grid>

        <!-- ═══════════════════════════════════════════
             BARRA DE TÍTULO PERSONALIZADA (Fluent 2)
             Canvas.ZIndex=1 para que flote sobre el NavigationView
             ═══════════════════════════════════════════ -->
        <Grid x:Name="AppTitleBar"
              Canvas.ZIndex="1"
              Height="{Binding ElementName=NavigationViewControl, Path=CompactPaneLength}"
              IsHitTestVisible="True"
              VerticalAlignment="Top">

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="48,0,0,0">

                <Image Source="/Assets/WindowIcon.ico"
                       Width="18" Height="18"
                       VerticalAlignment="Center"
                       AutomationProperties.Name="Logo institucional"/>

                <TextBlock x:Name="AppTitleBarText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </StackPanel>
        </Grid>

        <!-- ═══════════════════════════════════════════
             NAVIGATIONVIEW — Fluent NavPane
             ═══════════════════════════════════════════ -->
        <NavigationView x:Name="NavigationViewControl"
                        Canvas.ZIndex="0"
                        IsBackButtonVisible="Visible"
                        IsBackEnabled="{x:Bind ViewModel.IsBackEnabled, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.Selected, Mode=OneWay}"
                        IsSettingsVisible="True"
                        ExpandedModeThresholdWidth="1024"
                        CompactModeThresholdWidth="640"
                        OpenPaneLength="268"
                        DisplayModeChanged="NavigationViewControl_DisplayModeChanged"
                        AutomationProperties.Name="Navegación principal">

            <!-- ── SECCIÓN PRINCIPAL ── -->
            <NavigationView.MenuItems>

                <NavigationViewItem Content="Panel Principal"
                                    ToolTipService.ToolTip="Panel principal de tareas"
                                    helpers:NavigationHelper.NavigateTo="DSAapp.ViewModels.MainViewModel"
                                    AutomationProperties.Name="Panel Principal">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Registro de Oficios"
                                    ToolTipService.ToolTip="Captura y gestiona oficios institucionales"
                                    helpers:NavigationHelper.NavigateTo="DSAapp.ViewModels.OficiosViewModel"
                                    AutomationProperties.Name="Registro de Oficios">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator/>

                <!-- ── HERRAMIENTAS ── -->
                <NavigationViewItem Content="Intranet SII"
                                    ToolTipService.ToolTip="Acceso al Sistema de Información Institucional"
                                    helpers:NavigationHelper.NavigateTo="DSAapp.ViewModels.VistaWebViewModel"
                                    AutomationProperties.Name="Intranet SII">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="Shell_Escaner"
                                    helpers:NavigationHelper.NavigateTo="DSAapp.ViewModels.EscanerViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8D7;"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="Shell_CuadrículaDeDatos"
                                    helpers:NavigationHelper.NavigateTo="DSAapp.ViewModels.CuadrículaDeDatosViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80A;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="Shell_CuadrículaDeContenido"
                                    helpers:NavigationHelper.NavigateTo="DSAapp.ViewModels.CuadrículaDeContenidoViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xF0E2;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Uid="Shell_DetallesDeLista"
                                    helpers:NavigationHelper.NavigateTo="DSAapp.ViewModels.DetallesDeListaViewModel">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA37;" FontFamily="{StaticResource SymbolThemeFontFamily}"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- ── PLANTILLA DE ENCABEZADO DE PÁGINA ── -->
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="0,6,0,0">
                        <TextBlock Text="{Binding}"
                                   Style="{ThemeResource TitleTextBlockStyle}"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </Grid>
                </DataTemplate>
            </NavigationView.HeaderTemplate>

            <!-- ── BEHAVIORS (header automático) ── -->
            <i:Interaction.Behaviors>
                <behaviors:NavigationViewHeaderBehavior
                    DefaultHeader="{x:Bind ((ContentControl)ViewModel.Selected).Content, Mode=OneWay}">
                    <behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                        <DataTemplate>
                            <Grid Margin="0,6,0,0">
                                <TextBlock Text="{Binding}"
                                           Style="{ThemeResource TitleTextBlockStyle}"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </DataTemplate>
                    </behaviors:NavigationViewHeaderBehavior.DefaultHeaderTemplate>
                </behaviors:NavigationViewHeaderBehavior>
            </i:Interaction.Behaviors>

            <!-- ── FRAME DE CONTENIDO ── -->
            <Grid Margin="{StaticResource NavigationViewPageContentMargin}">
                <Frame x:Name="NavigationFrame">
                    <Frame.ContentTransitions>
                        <TransitionCollection>
                            <NavigationThemeTransition/>
                        </TransitionCollection>
                    </Frame.ContentTransitions>
                </Frame>
            </Grid>

        </NavigationView>
    </Grid>
</Page>