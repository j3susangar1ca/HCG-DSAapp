<Page x:Class="DSAapp.Views.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
      Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════
             ROW 0 — InfoBar para feedback de red
             ════════════════════════════════════════ -->
        <InfoBar Grid.Row="0"
                 x:Name="NetworkInfoBar"
                 IsOpen="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                 Severity="Informational"
                 Title="Sincronizando"
                 Message="Cargando tareas desde el servidor de red..."
                 IsClosable="False"
                 Margin="0,0,0,12"/>

        <!-- ════════════════════════════════════════
             ROW 1 — CommandBar nativo
             ════════════════════════════════════════ -->
        <CommandBar Grid.Row="1"
                    DefaultLabelPosition="Right"
                    Background="Transparent"
                    HorizontalAlignment="Left"
                    Padding="0,0,0,16"
                    OverflowButtonVisibility="Collapsed">

            <AppBarButton x:Name="RefreshButton"
                          Icon="Refresh"
                          Label="Actualizar"
                          Command="{x:Bind ViewModel.CargarTareasCommand}"
                          ToolTipService.ToolTip="Recargar desde la base de datos (F5)"
                          AutomationProperties.Name="Actualizar lista"/>

            <AppBarSeparator/>

            <AppBarButton Label="Nueva tarea"
                          Command="{x:Bind ViewModel.AgregarTareaPruebaCommand}"
                          AutomationProperties.Name="Agregar nueva tarea">
                <AppBarButton.Icon>
                    <FontIcon Glyph="&#xE710;"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"/>
                </AppBarButton.Icon>
            </AppBarButton>

        </CommandBar>

        <!-- ════════════════════════════════════════
             ROW 2 — Tarjetas KPI
             ════════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnSpacing="12" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- KPI: Total -->
            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="TOTAL DE TAREAS"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   CharacterSpacing="50"/>
                        <TextBlock Text="{x:Bind ViewModel.TotalTareas, Mode=OneWay}"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="40" Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE9D5;"
                                  FontSize="18"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- KPI: Completadas -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="COMPLETADAS"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   CharacterSpacing="50"/>
                        <TextBlock Text="{x:Bind ViewModel.TareasCompletadas, Mode=OneWay}"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="40" Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE73E;"
                                  FontSize="18"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- KPI: Pendientes -->
            <Border Grid.Column="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="PENDIENTES"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   CharacterSpacing="50"/>
                        <TextBlock Text="{x:Bind ViewModel.TareasPendientes, Mode=OneWay}"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="40" Height="40"
                            CornerRadius="20"
                            Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                            VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE916;"
                                  FontSize="18"
                                  FontFamily="{StaticResource SymbolThemeFontFamily}"
                                  Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ════════════════════════════════════════
             ROW 3 — DataGrid en card
             ════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>

                <!-- DataGrid -->
                <toolkit:DataGrid ItemsSource="{x:Bind ViewModel.Tareas, Mode=OneWay}"
                                  AutoGenerateColumns="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                  RowBackground="Transparent"
                                  AlternatingRowBackground="{ThemeResource SubtleFillColorSecondaryBrush}"
                                  SelectionMode="Extended"
                                  BorderThickness="0"
                                  CanUserSortColumns="True"
                                  CanUserReorderColumns="True"
                                  CanUserResizeColumns="True">
                    <toolkit:DataGrid.Columns>
                        <toolkit:DataGridCheckBoxColumn Header="✓"
                                                        Binding="{Binding EstaCompletada}"
                                                        Width="56"/>
                        <toolkit:DataGridTextColumn Header="Título"
                                                    Binding="{Binding Titulo}"
                                                    Width="*"/>
                        <toolkit:DataGridTextColumn Header="Descripción"
                                                    Binding="{Binding Descripcion}"
                                                    Width="1.5*"/>
                        <toolkit:DataGridTextColumn Header="Creado por"
                                                    Binding="{Binding CreadoPor}"
                                                    Width="Auto"
                                                    IsReadOnly="True"/>
                        <toolkit:DataGridTextColumn Header="Fecha"
                                                    Binding="{Binding FechaCreacion}"
                                                    Width="140"
                                                    IsReadOnly="True"/>
                    </toolkit:DataGrid.Columns>
                </toolkit:DataGrid>

                <!-- Estado vacío -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                         Converter={StaticResource BoolToInverseVisibility}}">
                    <FontIcon Glyph="&#xF16B;"
                              FontSize="40"
                              FontFamily="{StaticResource SymbolThemeFontFamily}"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No hay tareas registradas"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Presiona 'Nueva tarea' en la barra de herramientas para comenzar."
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

            </Grid>
        </Border>

    </Grid>
</Page>